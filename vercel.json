{
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/marketing-news/:slug",
      "destination": "/posts/:slug"
    }
  ],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "admin.infinites.co.kr"
        }
      ],
      "destination": "https://infinites.co.kr/admin/:path",
      "permanent": false
    },
    {
      "source": "/:path((?!admin).*)",
      "has": [
        {
          "type": "host",
          "value": "www.infinites.co.kr"
        }
      ],
      "destination": "https://infinites.co.kr/:path",
      "permanent": true
    },
    {
      "source": "/posts/:slug",
      "destination": "/marketing-news/:slug",
      "permanent": true
    }
  ]
}
